{
  "name": "intotechsupro/service-management-portal",
  "description": "Complete Multi-Role Service Management Portal",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0",
    "laravel/tinker": "^2.9",
    "laravel/websockets": "^1.15",
    "laravel/echo": "^1.17",
    "predis/predis": "^2.2"
  },
  "require-dev": {
    "laravel/pint": "^1.13",
    "laravel/sail": "^1.26",
    "mockery/mockery": "^1.6",
    "pestphp/pest": "^2.28"
